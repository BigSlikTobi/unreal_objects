# === Required in production (ENVIRONMENT=production) ===
ENVIRONMENT=production
INTERNAL_API_KEY=          # Shared secret for service-to-service auth
RULE_ENGINE_ADMIN_TOKEN=   # Required for destructive operations (DELETE)
MCP_ADMIN_API_KEY=         # Admin key for MCP server agent management

# === Service URLs (override for Railway / non-localhost deployments) ===
RULE_ENGINE_URL=http://127.0.0.1:8001
DECISION_CENTER_URL=http://127.0.0.1:8002
TOOL_AGENT_URL=http://127.0.0.1:8003

# === CORS (comma-separated origins, default "*") ===
ALLOWED_ORIGINS=https://your-ui.railway.app

# === LLM API keys (at least one required for rule translation) ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GPT_MODEL=gpt-4o-mini

# === Rule Engine persistence ===
RULE_ENGINE_PERSISTENCE_PATH=./data/rule_engine_store.json

# === Company Server (optional, uses COMPANY_ prefix in Pydantic) ===
COMPANY_ACCELERATION=10
COMPANY_BASE_CASES_PER_HOUR=6

# === UI build-time variables (Vite) ===
VITE_RULE_ENGINE_BASE_URL=https://rule-engine.railway.app
VITE_DECISION_CENTER_BASE_URL=https://decision-center.railway.app
VITE_TOOL_AGENT_BASE_URL=https://tool-agent.railway.app
